# Copy to .env and fill in. The real .env is gitignored.
# chmod 600 .env after creating.

# --- SMTP ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxx.xxxxxxxx
SMTP_FROM=competition@your-domain.org
SMTP_TLS=true
SMTP_DRY_RUN=false

# --- Evaluation ---
ENABLE_GPU=1
DATA_ROOT=/opt/celegans_hackathon_infra/data
DATABASE_URL=sqlite:////opt/celegans_hackathon_infra/runtime/orchestrator.db
QUEUE_DIR=/opt/celegans_hackathon_infra/runtime/queue
WORK_DIR=/opt/celegans_hackathon_infra/runtime/work
REGISTRATION_THRESHOLD=0.3
EVAL_TIMEOUT=7200
